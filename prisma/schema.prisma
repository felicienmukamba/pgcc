enum EthnicGroup {
  GROUP_A
  GROUP_B
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum SentenceType {
  IMPRISONMENT
  FINE
  COMMUNITY_SERVICE
}

enum ParoleStatus {
  ELIGIBLE
  GRANTED
  DENIED
}

enum RehabilitationStatus {
  PENDING
  COMPLETED
}

enum AppealStatus {
  NONE
  PENDING
  ACCEPTED
  REJECTED
}

enum MarriageType {
  CIVIL
  RELIGIOUS
  TRADITIONAL
}

enum ContractType {
  COMMUNITY_PROPERTY
  SEPARATION_OF_PROPERTY
}

// Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  username               String   @unique
  emailVerified          DateTime?
  image                  String?
  roles                  Role[]
  accountNonExpired      Boolean  @default(true)
  accountNonLocked       Boolean  @default(true)
  credentialsNonExpired  Boolean  @default(true)
  enabled                Boolean  @default(true)
  isUsing2FA             Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  citizen  Citizen?

  // Relations for different roles
  birthRecordsAsOfficiant    BirthRecord[]    @relation("BirthOfficiant")
  marriageRecordsAsOfficiant MarriageRecord[] @relation("MarriageOfficiant")
  deathRecordsAsOfficiant    DeathRecord[]    @relation("DeathOfficiant")
  consultationsAsDoctor      Consultation[]   @relation("Doctor")
  complaintsAsOfficer        Complaint[]      @relation("PoliceOfficer")
  convictionsAsProsecutor    Conviction[]     @relation("Prosecutor")
  divorceRecordsAsOfficiant  DivorceRecord[]  @relation("DivorceOfficiant")
  medicalExamsAsDoctor       MedicalExam[]    @relation("DoctorExam")
  auditLogs                  AuditLog[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Citizen {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  lastName                String
  firstName               String
  maidenName              String?
  birthDate               DateTime
  birthPlace              String
  nationalityID           String              @unique
  nationality             Nationality
  gender                  Gender
  ethnicGroup             EthnicGroup?
  community               String?
  territory               String?
  fatherId                String?
  motherId                String?
  currentAddress          String
  phoneNumber             String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  bloodType               BloodType?
  disabilities            String?
  educationLevel          String?
  profession              String?
  maritalStatus           MaritalStatus       @default(SINGLE)
  occupation              String?
  religion                String?
  voterStatus             String?
  taxIdentificationNumber String?
  socialSecurityNumber    String?
  drivingLicenseNumber    String?
  passportNumber          String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Relations parentales - IMPORTANT : noms distincts
  father Citizen?              @relation("FatherChild", fields: [fatherId], references: [id])
  mother Citizen?              @relation("MotherChild", fields: [motherId], references: [id])
  childrenAsFather Citizen[]    @relation("FatherChild")
  childrenAsMother Citizen[]    @relation("MotherChild")

  images                   Image[]


  birthRecordChild         BirthRecord?        @relation("ChildCitizen")
  birthRecordsDeclarer     BirthRecord[]       @relation("DeclarerCitizen")
  marriagesAsPartner1      MarriageRecord[]    @relation("Partner1")
  marriagesAsPartner2      MarriageRecord[]    @relation("Partner2")

  marriageRecordsAsWitness1  MarriageRecord[] @relation("MarriageWitness1")
  marriageRecordsAsWitness2  MarriageRecord[] @relation("MarriageWitness2")
  marriageRecordsAsWitness3  MarriageRecord[] @relation("MarriageWitness3")

  deathRecord              DeathRecord?
  deathRecordsAsDeclarer     DeathRecord[]    @relation("DeathDeclarer")
  consultations            Consultation[]      @relation("Patient")
  filedComplaints          Complaint[]         @relation("Plaintiff")
  receivedComplaints       Complaint[]         @relation("Accused")
  convictions              Conviction[]        @relation("Convicted")
  divorcesAsPartner1       DivorceRecord[]     @relation("DivorcePartner1")
  divorcesAsPartner2       DivorceRecord[]     @relation("DivorcePartner2")
  divorceWitness1          DivorceRecord[]     @relation("DivorceWitness1")
  divorceWitness2          DivorceRecord[]     @relation("DivorceWitness2")
  medicalExams             MedicalExam[]       @relation("PatientExam")
  webauthnCredentials      WebAuthnCredential[]
  faceDescriptors          FaceDescriptor[]

  fingerprintEmbedding FingerprintEmbedding[]

  @@map("citizens")
}

model Image {
  id        String   @id @default(cuid())
  path      String
  citizenId String?
  citizen   Citizen? @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  @@map("images")
}

model BirthRecord {
  id                 String    @id @default(cuid())
  registrationNumber String    @unique
  citizenId          String    @unique
  officiantId        String
  declarerId         String
  date               DateTime  @default(now())
  place              String
  childName          String
  gender             Gender
  birthDate          DateTime
  birthPlace         String
  weight             Float
  height             Float
  birthTime          String
  observations       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  citizen   Citizen  @relation("ChildCitizen", fields: [citizenId], references: [id], onDelete: Cascade)
  officiant User     @relation("BirthOfficiant", fields: [officiantId], references: [id])
  declarer  Citizen  @relation("DeclarerCitizen", fields: [declarerId], references: [id])

  @@map("birth_records")
}


model MarriageRecord {
  id             String        @id @default(cuid())
  partner1Id     String
  partner2Id     String
  marriagePlace  String
  marriageDate   DateTime
  officiantId    String
  witness1Id     String
  witness2Id     String
  witness3Id     String?
  marriageType   MarriageType
  contractType   ContractType?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  partner1  Citizen @relation("Partner1", fields: [partner1Id], references: [id])
  partner2  Citizen @relation("Partner2", fields: [partner2Id], references: [id])
  officiant User    @relation("MarriageOfficiant", fields: [officiantId], references: [id])
  witness1  Citizen    @relation("MarriageWitness1", fields: [witness1Id], references: [id])
  witness2  Citizen    @relation("MarriageWitness2", fields: [witness2Id], references: [id])
  witness3  Citizen?   @relation("MarriageWitness3", fields: [witness3Id], references: [id])

  @@map("marriage_records")
}

model DeathRecord {
  id                    String   @id @default(cuid())
  citizenId             String   @unique
  deathPlace            String
  deathDate             DateTime
  declarerId            String
  officiantId           String
  informantRelationship String
  funeralPlace          String?
  cemeteryName          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  citizen   Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  declarer  Citizen    @relation("DeathDeclarer", fields: [declarerId], references: [id])
  officiant User    @relation("DeathOfficiant", fields: [officiantId], references: [id])

  @@map("death_records")
}

model Consultation {
  id             String        @id @default(cuid())
  date           DateTime      @default(now())
  diagnosis      String
  price          Float
  duration       String
  notes          String?
  doctorId       String
  patientId      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  doctor         User          @relation("Doctor", fields: [doctorId], references: [id])
  patient        Citizen       @relation("Patient", fields: [patientId], references: [id])
  prescriptions Prescription[]
  medicalExams  MedicalExam[]

  @@map("consultations")
}

model Prescription {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  dosage         String
  duration         String
  quantity       String
  status         String
  consultationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultation Consultation? @relation(fields: [consultationId], references: [id])
  medications  Medication[]

  @@map("prescriptions")
}

model Medication {
  id           String @id @default(cuid())
  tradeName    String
  genericName  String
  dosage       String
  unit         String
  adminRoute   String
  manufacturer String
  description  String?

  prescriptions Prescription[]

  @@map("medications")
}

model Complaint {
  id              String          @id @default(cuid())
  plaintiffId     String
  accusedId       String?
  date            DateTime        @default(now())
  description     String
  place           String
  type            String
  status          ComplaintStatus @default(PENDING)
  witnesses       String?
  evidence        String?
  policeOfficerId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  plaintiff       Citizen @relation("Plaintiff", fields: [plaintiffId], references: [id])
  accused         Citizen? @relation("Accused", fields: [accusedId], references: [id])
  policeOfficer   User    @relation("PoliceOfficer", fields: [policeOfficerId], references: [id])

  @@map("complaints")
}

model Conviction {
  id                   String              @id @default(cuid())
  date                 DateTime            @default(now())
  jurisdiction         String
  court                String
  offenseNature        String
  duration             String?
  fineAmount           Float?
  startDate            DateTime?
  endDate              DateTime?
  status               String
  sentence             String
  sentenceType         SentenceType
  paroleStatus         ParoleStatus?
  rehabilitationStatus RehabilitationStatus?
  appealStatus         AppealStatus        @default(NONE)
  citizenId            String
  prosecutorId         String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  citizen    Citizen @relation("Convicted", fields: [citizenId], references: [id])
  prosecutor User    @relation("Prosecutor", fields: [prosecutorId], references: [id])

  @@map("convictions")
}

model WebAuthnCredential {
  id           String   @id @default(cuid())
  citizenId    String
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  type         String   // "fingerprint", "face", "security-key"
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  citizen Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  @@map("webauthn_credentials")
}

model FaceDescriptor {
  id          String   @id @default(uuid())
  citizenId   String
  descriptor  Float[]
  confidence  Float?
  citizen     Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)
}

model FingerprintEmbedding {
  id        String    @id @default(cuid())
  citizenId String    @unique
  embedding Float[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  citizen Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)

  @@map("fingerprint_embeddings")
}

model DivorceRecord {
  id                 String   @id @default(cuid())
  registrationNumber String   @unique
  partner1Id         String
  partner2Id         String
  marriageRecordId   String?  @unique
  divorceDate        DateTime
  divorcePlace       String
  officiantId        String
  witness1Id         String
  witness2Id         String
  reason             String?
  judgementNumber    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  partner1  Citizen @relation("DivorcePartner1", fields: [partner1Id], references: [id])
  partner2  Citizen @relation("DivorcePartner2", fields: [partner2Id], references: [id])
  officiant User    @relation("DivorceOfficiant", fields: [officiantId], references: [id])
  witness1  Citizen @relation("DivorceWitness1", fields: [witness1Id], references: [id])
  witness2  Citizen @relation("DivorceWitness2", fields: [witness2Id], references: [id])

  @@map("divorce_records")
}

model MedicalExam {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  examType       String
  results        String
  observations   String?
  doctorId       String
  patientId      String
  consultationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  doctor       User          @relation("DoctorExam", fields: [doctorId], references: [id])
  patient      Citizen       @relation("PatientExam", fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])

  @@map("medical_exams")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, VIEW
  entity    String   // Table name or Module name
  entityId  String?  // ID of the affected record
  details   String?  // Description or JSON string of changes
  ipAddress String?
  createdAt DateTime @default(now())

  // Tamper-Evident Chain
  prevHash  String?
  hash      String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// Secure Identity Model
model CitizenIdentity {
  id            String   @id @default(uuid()) // UUIDv7 manually implemented if needed, or default uuid
  nationalId    String   @unique
  passwordHash  String
  mfaSecret     String?
  mfaEnabled    Boolean  @default(false)
  
  // Relations
  profile       CitizenProfile?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("citizen_identities")
}

// Encrypted Profile Data (PII)
model CitizenProfile {
  id             String          @id @default(cuid())
  identityId     String          @unique
  identity       CitizenIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  
  encryptedData  String          @db.Text // AES-256-GCM encrypted JSON blob
  
  // Searchable fields (hashed/blind index)
  emailHash      String?         @unique
  phoneNumberHash String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("citizen_profiles")
}